<div class="mb-6 flex items-center justify-between">
  <div>
    <h2 class="text-2xl font-bold text-gray-800 capitalize">Kelola Permission — <span class="text-indigo-600">
        <%= role.name %>
      </span></h2>
    <p class="text-sm text-gray-500 mt-1">Assign atau cabut permission dari role ini.</p>
  </div>
  <a href="/roles" class="text-sm text-gray-500 hover:text-indigo-600 transition">← Kembali ke Roles</a>
</div>

<div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
  <!-- Kolom kiri: Permission yang sudah diassign -->
  <div class="bg-white rounded-xl shadow-sm border border-gray-200">
    <div class="px-5 py-4 border-b border-gray-200">
      <h3 class="font-semibold text-gray-700 text-sm">✅ Sudah Diassign (<%= assignedIds.length %>)</h3>
    </div>
    <div class="divide-y divide-gray-100">
      <% const assigned=allPermissions.filter(p=> assignedIds.includes(p.id)); %>
        <% if (assigned.length===0) { %>
          <p class="text-center py-8 text-gray-400 text-sm">Belum ada permission yang diassign</p>
          <% } %>
            <% assigned.forEach(p=> { %>
              <div class="flex items-center justify-between px-5 py-3">
                <div>
                  <span class="text-sm font-medium text-gray-800">
                    <%= p.name %>
                  </span>
                  <span class="ml-2 text-xs text-gray-400">
                    <%= p.resource %> / <%= p.action %>
                  </span>
                </div>
                <form action="/roles/<%= role.id %>/permissions/<%= p.id %>?_method=DELETE" method="POST">
                  <button type="submit" class="text-xs text-red-500 hover:text-red-700 font-medium transition">
                    Cabut
                  </button>
                </form>
              </div>
              <% }) %>
    </div>
  </div>

  <!-- Kolom kanan: Assign permission baru -->
  <div class="bg-white rounded-xl shadow-sm border border-gray-200">
    <div class="px-5 py-4 border-b border-gray-200">
      <h3 class="font-semibold text-gray-700 text-sm">➕ Assign Permission Baru</h3>
    </div>
    <div class="p-5">
      <% const unassigned=allPermissions.filter(p=> !assignedIds.includes(p.id)); %>
        <% if (unassigned.length===0) { %>
          <p class="text-center py-6 text-gray-400 text-sm">Semua permission sudah diassign 🎉</p>
          <% } else { %>
            <form action="/roles/<%= role.id %>/permissions" method="POST" class="space-y-4">
              <div>
                <label for="permission_id" class="block text-sm font-medium text-gray-700 mb-1">Pilih Permission</label>
                <select id="permission_id" name="permission_id" required
                  class="w-full px-4 py-2.5 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500 bg-white transition">
                  <option value="">-- Pilih permission --</option>
                  <% unassigned.forEach(p=> { %>
                    <option value="<%= p.id %>">
                      <%= p.name %>
                    </option>
                    <% }) %>
                </select>
              </div>
              <button type="submit"
                class="w-full bg-indigo-600 hover:bg-indigo-700 text-white font-medium py-2.5 px-4 rounded-lg transition text-sm">
                Assign Permission
              </button>
            </form>
            <% } %>
    </div>
  </div>
</div>