<!-- src/views/users/list.ejs -->
<div class="bg-white p-6 rounded-lg shadow-md">
  <div class="flex justify-between items-center mb-6">
    <h2 class="text-2xl font-bold text-gray-800">Manajemen Pengguna</h2>
    <a href="/users/create" class="bg-blue-600 text-white px-4 py-2 rounded-lg hover:bg-blue-700 transition">
      + Tambah User
    </a>
  </div>

  <div class="overflow-x-auto">
    <table class="w-full text-left border-collapse">
      <thead>
        <tr class="bg-gray-100 text-gray-700 uppercase text-sm leading-normal">
          <th class="py-3 px-6 text-left">ID</th>
          <th class="py-3 px-6 text-left">Username</th>
          <th class="py-3 px-6 text-left">Role</th>
          <th class="py-3 px-6 text-center">Aksi</th>
        </tr>
      </thead>
      <tbody class="text-gray-600 text-sm font-light">
        <% users.forEach(user=> { %>
          <tr class="border-b border-gray-200 hover:bg-gray-50">
            <td class="py-3 px-6">
              <%= user.id %>
            </td>
            <td class="py-3 px-6 font-medium">
              <%= user.username %>
            </td>
            <td class="py-3 px-6">
              <span class="bg-purple-200 text-purple-600 py-1 px-3 rounded-full text-xs">
                <%= user.role_name || 'No Role' %>
              </span>
            </td>
            <td class="py-3 px-6 text-center">
              <div class="flex item-center justify-center space-x-4">
                <!-- Tombol Hapus dengan Method Override -->
                <form action="/users/<%= user.id %>?_method=DELETE" method="POST"
                  onsubmit="return confirm('Yakin mau hapus user ini?')">
                  <button type="submit" class="text-red-500 hover:text-red-700">
                    Hapus
                  </button>
                </form>
              </div>
            </td>
          </tr>
          <% }) %>
      </tbody>
    </table>
  </div>
</div>