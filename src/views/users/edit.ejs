<div class="max-w-lg mx-auto">
  <div class="mb-6 flex items-center justify-between">
    <h2 class="text-2xl font-bold text-gray-800">Edit User</h2>
    <a href="/users" class="text-sm text-gray-500 hover:text-indigo-600 transition">← Kembali</a>
  </div>

  <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6">
    <div class="mb-5 p-4 bg-gray-50 rounded-lg border border-gray-200">
      <p class="text-xs text-gray-500 mb-1">Username</p>
      <p class="font-semibold text-gray-800">
        <%= targetUser.username %>
      </p>
    </div>

    <form action="/users/<%= targetUser.id %>?_method=PUT" method="POST" class="space-y-5">
      <div>
        <label for="role_id" class="block text-sm font-medium text-gray-700 mb-1">Ganti Role</label>
        <select id="role_id" name="role_id" required
          class="w-full px-4 py-2.5 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent transition bg-white">
          <% roles.forEach(role=> { %>
            <option value="<%= role.id %>" <%=targetUser.role_id===role.id ? 'selected' : '' %>>
              <%= role.name %>
            </option>
            <% }) %>
        </select>
      </div>

      <div class="flex gap-3 pt-2">
        <button type="submit"
          class="flex-1 bg-indigo-600 hover:bg-indigo-700 text-white font-medium py-2.5 px-4 rounded-lg transition text-sm">
          Update Role
        </button>
        <a href="/users"
          class="flex-1 text-center bg-gray-100 hover:bg-gray-200 text-gray-700 font-medium py-2.5 px-4 rounded-lg transition text-sm">
          Batal
        </a>
      </div>
    </form>
  </div>
</div>