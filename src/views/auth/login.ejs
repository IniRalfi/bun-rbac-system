<!DOCTYPE html>
<html lang="id">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>
    <%= title %>
  </title>
  <link href="/css/tailwind.css" rel="stylesheet">
</head>

<body class="bg-gray-100 min-h-screen flex items-center justify-center">
  <div class="w-full max-w-sm">
    <!-- Card -->
    <div class="bg-white rounded-2xl shadow-lg border border-gray-200 overflow-hidden">
      <!-- Header card -->
      <div class="bg-gray-900 px-6 py-8 text-center">
        <div class="w-12 h-12 bg-indigo-500 rounded-xl flex items-center justify-center mx-auto mb-3">
          <span class="text-white font-black text-xl">R</span>
        </div>
        <h1 class="text-white font-bold text-xl">RBAC System</h1>
        <p class="text-gray-400 text-sm mt-1">Role-Based Access Control</p>
      </div>

      <!-- Form -->
      <div class="px-6 py-6">
        <% if (errorMessage) { %>
          <div class="mb-4 p-3 bg-red-50 border border-red-200 rounded-lg">
            <p class="text-sm text-red-600 font-medium">
              <%= errorMessage %>
            </p>
          </div>
          <% } %>

            <form action="/login" method="POST" class="space-y-4">
              <div>
                <label for="username" class="block text-sm font-medium text-gray-700 mb-1">Username</label>
                <input type="text" id="username" name="username" required autofocus
                  class="w-full px-4 py-2.5 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent transition"
                  placeholder="Masukkan username">
              </div>

              <div>
                <label for="password" class="block text-sm font-medium text-gray-700 mb-1">Password</label>
                <input type="password" id="password" name="password" required
                  class="w-full px-4 py-2.5 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent transition"
                  placeholder="Masukkan password">
              </div>

              <button type="submit"
                class="w-full bg-indigo-600 hover:bg-indigo-700 text-white font-semibold py-2.5 rounded-lg transition text-sm mt-2">
                Login
              </button>
            </form>
      </div>
    </div>

    <p class="text-center text-xs text-gray-400 mt-4">
      &copy; <%= new Date().getFullYear() %> RBAC System — Bun.js + Express
    </p>
  </div>
</body>

</html>