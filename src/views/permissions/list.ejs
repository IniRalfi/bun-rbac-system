<div class="bg-white rounded-xl shadow-sm border border-gray-200">
  <div class="flex justify-between items-center px-6 py-4 border-b border-gray-200">
    <h2 class="text-lg font-semibold text-gray-800">Daftar Permission</h2>
    <a href="/permissions/create"
      class="bg-indigo-600 hover:bg-indigo-700 text-white text-sm font-medium px-4 py-2 rounded-lg transition">
      + Tambah Permission
    </a>
  </div>

  <div class="overflow-x-auto">
    <table class="w-full text-sm">
      <thead>
        <tr class="bg-gray-50 text-gray-500 uppercase text-xs tracking-wider">
          <th class="py-3 px-6 text-left font-semibold">#</th>
          <th class="py-3 px-6 text-left font-semibold">Name</th>
          <th class="py-3 px-6 text-left font-semibold">Resource</th>
          <th class="py-3 px-6 text-left font-semibold">Action</th>
          <th class="py-3 px-6 text-center font-semibold">Aksi</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-gray-100">
        <% if (permissions.length===0) { %>
          <tr>
            <td colspan="5" class="py-10 text-center text-gray-400">Belum ada data permission</td>
          </tr>
          <% } %>
            <% permissions.forEach((perm, index)=> { %>
              <tr class="hover:bg-gray-50 transition">
                <td class="py-3 px-6 text-gray-400">
                  <%= index + 1 %>
                </td>
                <td class="py-3 px-6">
                  <span class="font-mono text-xs bg-gray-100 text-gray-700 px-2 py-1 rounded">
                    <%= perm.name %>
                  </span>
                </td>
                <td class="py-3 px-6 text-gray-600">
                  <%= perm.resource %>
                </td>
                <td class="py-3 px-6">
                  <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium
                <% if (perm.action === 'delete') { %> bg-red-100 text-red-700
                <% } else if (perm.action === 'create') { %> bg-green-100 text-green-700
                <% } else if (perm.action === 'edit') { %> bg-yellow-100 text-yellow-700
                <% } else { %> bg-blue-100 text-blue-700 <% } %>">
                    <%= perm.action %>
                  </span>
                </td>
                <td class="py-3 px-6 text-center">
                  <form action="/permissions/<%= perm.id %>?_method=DELETE" method="POST"
                    onsubmit="return confirm('Yakin hapus permission <%= perm.name %>?')">
                    <button type="submit" class="text-red-500 hover:text-red-700 font-medium transition text-xs">
                      Hapus
                    </button>
                  </form>
                </td>
              </tr>
              <% }) %>
      </tbody>
    </table>
  </div>

  <div class="px-6 py-3 border-t border-gray-100">
    <p class="text-xs text-gray-400">Total: <%= permissions.length %> permission</p>
  </div>
</div>