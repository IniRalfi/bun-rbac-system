<header class="bg-white border-b border-gray-200 px-6 py-4 flex items-center justify-between shadow-sm">
  <div>
    <h1 class="text-xl font-semibold text-gray-800">
      <%= title %>
    </h1>
    <p class="text-xs text-gray-400 mt-0.5">RBAC System — Role-Based Access Control</p>
  </div>
  <% if (typeof user !=='undefined' && user) { %>
    <div class="flex items-center gap-4">
      <div class="text-right">
        <p class="text-sm font-medium text-gray-700">
          <%= user.username %>
        </p>
        <p class="text-xs text-indigo-500 font-semibold uppercase tracking-wide">
          Role ID: <%= user.role_id %>
        </p>
      </div>
      <div class="w-9 h-9 rounded-full bg-indigo-600 flex items-center justify-center text-white font-bold text-sm">
        <%= user.username.charAt(0).toUpperCase() %>
      </div>
      <a href="/logout"
        class="text-sm text-red-500 hover:text-red-700 border border-red-200 hover:border-red-400 px-3 py-1.5 rounded-lg transition">
        Logout
      </a>
    </div>
    <% } %>
</header>